{
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "./dist-package",
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "experimentalDecorators": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "noEmit": true,
    "jsx": "react",
    "paths": {
      "~integration/*": ["cypress/*"]
    }
  },
  "include": ["../../@types/**/*", "src/**/*"]
}
