{
  "name": "@toptal/staff-portal",
  "description": "Toptal frontend application created with Davinci CLI",
  "version": "1.1361.2",
  "author": "Toptal",
  "homepage": "https://github.com/toptal/staff-portal/tree/master#readme",
  "license": "ISC",
  "variables": {
    "max_lint_warnings": "24"
  },
  "scripts": {
    "analyze": "davinci engine analyze",
    "build": "yarn generate:types && davinci engine build && cp -r ./dist ../../dist",
    "build:ci": "davinci engine build && cp -r ./dist ../../dist",
    "build:production": "davinci engine build --dotenv .env.production && cp -r ./dist ../../dist",
    "build:staging": "davinci engine build --dotenv .env.staging && cp -r ./dist ../../dist",
    "build:temploy": "davinci engine build --dotenv .env.temploy && cp -r ./dist ../../dist",
    "build:testbox": "yarn generate:types && davinci engine build --skip-type-checking --disable-source-maps && cp -r ./dist ../../dist",
    "generate:types": "kurama generate-types",
    "generate:types-combined": "graphql-codegen -c codegen-combined.js",
    "generate:types:watch": "kurama generate-types --watch",
    "lint": "MAX_WARNINGS=$npm_package_variables_max_lint_warnings kurama lint",
    "size": "davinci engine size --limit 2.95mb",
    "size:local": "yarn build && yarn size",
    "start": "yarn --cwd=../.. start",
    "start:ci": "NODE_ENV=test davinci engine start --open false --dotenv .env.ci",
    "start:cucumber": "NODE_ENV=production yarn davinci engine start --open false --dotenv .env.cucumber",
    "start:cucumber:local": "yarn --cwd=../.. generate:types && NODE_ENV=production yarn davinci engine start --open false --dotenv .env.cucumber",
    "start:local": "yarn --cwd=../.. generate:types:local && davinci engine start --open false --dotenv .env.local_development",
    "start:staging": "davinci engine start --https --open-url https://local-development.staging.toptal.net --dotenv .env.development --overlay false",
    "start:temploy": "PORT=4015 davinci engine start --https --open-url https://local-development.toptal.rocks --dotenv .env.temploy",
    "test": "yarn test:unit",
    "test:coverage": "yarn test --coverage true",
    "test:ui:ci": "NODE_ENV=test WAIT_ON_TIMEOUT=480000 start-server-and-test start:ci http://localhost:4016 'davinci-qa integration --config-file ./cypress.ci.json'",
    "test:ui:open": "kill -9 $(lsof -t -i :4016) 2> /dev/null; NODE_ENV=test start-server-and-test start:ci http://localhost:4016 'davinci-qa integration --config-file ./cypress.json --open'",
    "test:ui:run": "NODE_ENV=test start-server-and-test start:ci http://localhost:4016 'davinci-qa integration --config-file ./cypress.json'",
    "test:unit": "LANG=en_US TZ=UTC NODE_ENV=test kurama test --config config/_jest/jest.specs.js",
    "test:unit:debug": "LANG=en_US TZ=UTC NODE_ENV=test node --inspect-brk --unhandled-rejections=strict ../../node_modules/.bin/davinci qa unit --config ./config/_jest/jest.specs.js",
    "test:watch": "yarn test --watch true",
    "typecheck": "kurama typecheck",
    "typecheck:cypress": "tsc --project cypress/tsconfig.json"
  },
