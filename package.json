{
  "name": "@toptal/staff-portal-monorepo",
  "description": "Staff Portal monorepo",
  "version": "0.0.1",
  "author": "Toptal",
  "homepage": "https://github.com/toptal/modularity-template/tree/master#readme",
  "license": "SEE LICENSE IN LICENSE.MD",
  "scripts": {
    "build": "yarn lerna run build --scope=@toptal/staff-portal --stream",
    "build:ci": "yarn lerna run build:ci --scope=@toptal/staff-portal --stream",
    "build:production": "yarn lerna run build:production --scope=@toptal/staff-portal --stream",
    "build:staging": "yarn lerna run build:staging --scope=@toptal/staff-portal --stream",
    "build:temploy": "yarn lerna run build:temploy --scope=@toptal/staff-portal --stream",
    "build:testbox": "yarn lerna run build:testbox --scope=@toptal/staff-portal --stream",
    "depcheck": "yarn lerna exec depcheck --stream --no-bail --since origin/master --exclude-dependents",
    "detect-circularity": "yarn davinci monorepo detect-circularity",
    "fetch:clean-schemas": "./_scripts/clean-schemas-folder.sh",
    "fetch:graphql-gateway-schema": "./_scripts/fetch-schema.sh staff",
    "fetch:graphql-lens-schema": "./_scripts/fetch-schema.sh lens",
    "fetch:graphql-schemas": "yarn fetch:clean-schemas && concurrently -r \"yarn fetch:graphql-lens-schema\" \"yarn fetch:graphql-gateway-schema\"",
    "fetch:graphql-schemas:introspection": "./_scripts/fetch-schema-introspection.sh",
    "fetch:graphql-schemas:local": "yarn fetch:clean-schemas && concurrently -r \"yarn fetch:graphql-lens-schema\" \"yarn fetch:graphql-schemas:introspection http://localhost:8082/gateway/graphql/staff/graphql\"",
    "fetch:graphql-schemas:production": "yarn fetch:clean-schemas && concurrently -r \"yarn fetch:graphql-lens-schema production\" \"yarn fetch:graphql-gateway-schema production\"",
    "generate-certificate": "./_scripts/generate-certificate.js",
    "generate:types": "yarn fetch:graphql-schemas && yarn generate:types:from-local-schema",
    "generate:types:from-local-schema": "yarn lerna run generate:types-combined --parallel --stream",
    "generate:types:from-root-schema": "yarn lerna run generate:types-combined --stream && yarn --cwd=namespaces/billing/apps/billing generate:types",
    "generate:types:local": "yarn fetch:graphql-schemas:local && yarn lerna run generate:types-combined --parallel --stream",
    "generate:types:production": "yarn fetch:graphql-schemas:production && yarn generate:types:from-root-schema",
    "generate:types:watch": "yarn lerna run generate:types:watch --parallel --ignore=@toptal/billing-frontend --stream",
    "lint": "yarn lerna run lint --stream",
    "lint:changed": "yarn lint --since origin/master --exclude-dependents",
    "lint:ci": "if node ./_scripts/check-non-root-changes.js; then yarn lint:changed; else yarn lint; fi",
    "packages:validate": "yarn lerna exec validate-package --stream --no-bail --no-prefix",
    "packages:validate:changed": "yarn packages:validate --since origin/master --exclude-dependents",
    "pact:ci": "NODE_ENV=test CI=true npm run pact --workspaces --if-present -- -i --bail --silent",
    "pact:publish": "./_scripts/publish_pact.js",
    "pact:verify": "./_scripts/verify_pact.sh 'Billing Frontend' && ./_scripts/verify_pact.sh 'Staff Portal'",
    "patch-package-silently": "([ -f ./node_modules/.bin/patch-package ] && [ -d ./patches ] && patch-package) || true",
    "postinstall": "yarn patch-package-silently && yarn lerna bootstrap",
    "prepare": "husky install",
    "prepublish": "if [ -f 'yarn.lock' ]; then yarn-deduplicate yarn.lock; fi",
    "release": "yarn lerna version",
    "release-package": "yarn lerna run release-package --stream",
    "size": "yarn lerna run size --scope=@toptal/staff-portal --stream",
    "start": "yarn generate:types && yarn start:dev --stream",
    "start:ci": "yarn lerna run start:ci --scope=@toptal/staff-portal --stream",
    "start:cucumber": "yarn generate:types:from-local-schema && yarn lerna run start:cucumber --scope=@toptal/staff-portal --stream",
    "start:dev": "yarn lerna run start:staging --scope=@toptal/staff-portal --stream",
    "start:local": "yarn lerna run start:local --scope=@toptal/staff-portal --stream",
    "storybook": "yarn kurama storybook",
    "syncpack:fix": "syncpack fix-mismatches",
    "test": "node ./_scripts/test-with-cwd.js",
    "test:changed": "yarn lerna run test --since origin/master --exclude-dependents --no-bail",
    "test:ci": "./_scripts/run-jest-parallel.js",
    "test:count-tests": "./_scripts/count-package-tests.mjs",
    "test:ui:ci": "./_scripts/run-cypress-parallel.js",
    "typecheck": "yarn typecheck:combined && yarn --cwd=namespaces/billing/apps/billing typecheck",
    "typecheck:combined": "NODE_OPTIONS=--max_old_space_size=4096 tsc --noEmit --project tsconfig.combined.json",
    "typecheck:cypress": "yarn lerna run typecheck:cypress --stream"
  },
  "execScript": {
    "fetch:graphql-lens-schema": "./_scripts/fetch-lens-schema.sh",
    "fetch:graphql-gateway-schema": "./_scripts/fetch-staff-schema.sh"
  },
  "dependencies": {
    "@changesets/changelog-github": "^0.4.0",
    "@changesets/cli": "^2.16.0",
    "@graphql-codegen/add": "^2.0.2",
    "@graphql-codegen/cli": "^1.21.4",
    "@graphql-codegen/fragment-matcher": "^2.0.1",
    "@graphql-codegen/introspection": "^1.18.2",
    "@graphql-codegen/near-operation-file-preset": "^1.18.0",
    "@graphql-codegen/typed-document-node": "^2.2.1",
    "@graphql-codegen/typescript": "^1.22.0",
    "@graphql-codegen/typescript-operations": "^1.17.16",
    "@graphql-codegen/typescript-react-apollo": "^2.2.1",
    "@graphql-codegen/typescript-resolvers": "^1.20.0",
    "@graphql-typed-document-node/core": "^3.1.0",
    "@lerna/cli": "4.0.0",
    "@lerna/run": "4.0.0",
    "@toptal/browserslist-config": "^1.2.0",
    "@toptal/davinci": "15.1.0",
    "concurrently": "^7.2.1",
    "cross-env": "^7.0.3",
    "get-graphql-schema": "^2.1.2",
    "graphql": "^15.5.0",
    "lerna": "^4.0.0",
    "patch-package": "^6.4.7",
    "shelljs": "^0.8.4",
    "string-replace-webpack-plugin": "^0.1.3",
    "syncpack": "^5.8.15",
    "typescript": "4.6.2",
    "yargs": "^17.0.1",
    "yarn-deduplicate": "^3.0.0"
  },
  "devDependencies": {
    "@miovision/eslint-plugin-disallow-date": "^2.0.0",
    "@staff-portal/kurama": "0.0.1",
    "@storybook/addon-a11y": "6.3.7",
    "@storybook/addon-actions": "6.3.7",
    "@storybook/addon-backgrounds": "6.5.5",
    "@storybook/addon-console": "1.2.3",
    "@storybook/addon-controls": "6.3.7",
    "@storybook/addon-docs": "6.3.7",
    "@storybook/addon-links": "6.3.12",
    "@storybook/addon-measure": "6.5.5",
    "@storybook/addon-outline": "6.5.5",
    "@storybook/addon-queryparams": "6.2.9",
    "@storybook/addon-storysource": "6.3.7",
    "@storybook/addon-toolbars": "6.3.7",
    "@storybook/addon-viewport": "6.3.7",
    "@storybook/builder-webpack5": "6.3.7",
    "@storybook/manager-webpack5": "6.3.7",
    "@storybook/react": "6.3.7",
    "@testing-library/dom": "^7.31.0",
    "del": "^6.1.1",
    "depcheck": "^1.4.3",
    "eslint-plugin-filename-rules": "^1.2.0",
    "husky": "^8.0.0",
    "jest-fail-on-console": "^2.4.1",
    "lint-staged": "^12.1.7",
    "markdownlint-cli": "^0.28.1",
    "prettier": "^2.4.1",
    "selfsigned": "^1.10.8"
  },
  "private": true,
  "resolutions": {
    "@topkit/react-router": "^0.3.4",
    "@topkit/router": "^0.6.4",
    "@toptal/picasso-provider": "^0.7.0",
    "@types/react-dom": "16.9.7",
    "final-form": "4.20.2",
    "i18next": "20.5.0",
    "postcss": "^8.4.0",
    "react-final-form": "6.5.3",
    "react-i18next": "11.10.0",
    "react-refresh": "^0.11.0"
  },
  "workspaces": [
    "hosts/*",
    "libs/*",
    "monorepo-helpers/*",
    "namespaces/billing/apps/*",
    "namespaces/billing/libs/*",
    "namespaces/clients/apps/*",
    "namespaces/clients/libs/*",
    "namespaces/community/apps/*",
    "namespaces/community/libs/*",
    "namespaces/engagements/apps/*",
    "namespaces/engagements/libs/*",
    "namespaces/facilities/apps/*",
    "namespaces/facilities/libs/*",
    "namespaces/jobs/apps/*",
    "namespaces/jobs/libs/*",
    "namespaces/staff/apps/*",
    "namespaces/staff/libs/*",
    "namespaces/talents/apps/*",
    "namespaces/talents/libs/*"
  ]
}
