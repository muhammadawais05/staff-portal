{
  "name": "@toptal/billing-frontend",
  "description": "React version of Billing based on Picasso",
  "version": "1.784.2",
  "author": "Toptal",
  "bugs": "https://github.com/toptal/billing-frontend/issues",
  "homepage": "https://github.com/toptal/billing-frontend#readme",
  "license": "SEE LICENSE IN LICENSE.MD",
  "main": "./src/index.staff-portal.ts",
  "repository": "git@github.com:toptal/staff-portal.git",
  "variables": {
    "max_lint_warnings": "80"
  },
  "scripts": {
    "build:package:legacy": "cross-env NODE_ENV=production SENTRY=true ./bin/build-legacy-package.sh",
    "build:package:legacy:analyze": "cross-env NODE_ENV=production APP_ANALYZE=true ./bin/build-legacy-package.sh",
    "clear": "yarn report:combined:clear && yarn clear:babelCache && yarn clear:coverage && yarn pact:clear",
    "clear:babelCache": "rm -rf ./node_modules/.cache/babel-loader",
    "clear:coverage": "yarn test:ui:clear && rm -rf ./coverage",
    "combinedCoverage": "yarn clear:coverage && yarn report:combined:clear && yarn test:coverage && yarn test:ui:ci && yarn combinedCoverage:report",
    "combinedCoverage:check": "yarn report:combined && yarn report:combined:check",
    "combinedCoverage:report": "yarn report:combined && yarn report:combined:report --skip-full",
    "generate:component": "hygen component new",
    "generate:context": "hygen context new",
    "generate:types": "kurama generate-types && yarn run prettier --write $(git diff --relative --name-only --diff-filter d | grep -E '\\.types.tsx$|__generated__/index.tsx$|fragmentTypes.json$' | xargs)",
    "generate:types:watch": "kurama generate-types --watch=\"src/**/*.graphql.ts\"",
    "install:to-platform": "cross-env NODE_ENV=production enableMinification=false ./bin/build-legacy-package.sh && rm -rf ../../../platform/node_modules/@toptal/billing-frontend-legacy && cp -r dist/platform ../../../platform/node_modules/@toptal/billing-frontend-legacy",
    "lint": "MAX_WARNINGS=$npm_package_variables_max_lint_warnings kurama lint",
    "pact": "kurama pact",
    "release-package": "cross-env ./bin/release-package.sh",
    "report:combined": "yarn report:combined:clear && yarn report:combined:make && yarn report:combined:copy && yarn report:combined:merge",
    "report:combined:check": "nyc check-coverage --nycrc-path ./config/_nyc/nyc.check.js",
    "report:combined:clear": "rm -rf ./.coverage/combined-report && rm -rf ./.coverage/temp && rm -rf ./.nyc_output",
    "report:combined:copy": "cp ./.coverage/cypress-coverage/coverage-final.json ./.coverage/temp/from-cypress.json && cp ./coverage/coverage-final.json ./.coverage/temp/from-jest.json",
    "report:combined:make": "mkdir ./.coverage/combined-report && mkdir ./.coverage/temp",
    "report:combined:merge": "nyc merge ./.coverage/temp ./.coverage/temp/coverage-final.json",
    "report:combined:report": "nyc report --nycrc-path ./config/_nyc/nyc.report.js",
    "start": "cross-env API_ENV=STAGING ../../../../_scripts/set-up-env.sh yarn start:dev",
    "start:analyze": "yarn clear:babelCache && cross-env NODE_ENV=development APP_ANALYZE=true TS_NODE_PROJECT=\"tsconfig.webpack.json\" webpack-dev-server --config ./config/webpack.analyze.ts --color --progress",
    "start:ci": "yarn clear:babelCache && cross-env NODE_ENV=test TS_NODE_PROJECT=\"tsconfig.webpack.json\" webpack-dev-server --config ./config/webpack.cypress.js --color",
    "start:dev": "yarn storybook",
    "start:https": "cross-env API_ENV=STAGING HTTPS=true ../../../../_scripts/set-up-env.sh yarn start:dev",
    "start:local": "cross-env API_ENV=LOCAL ../../../../_scripts/set-up-env.sh yarn start:dev",
    "start:temploy": "cross-env API_ENV=TEMPLOY ../../../../_scripts/set-up-env.sh yarn start:dev",
    "stop": "pkill -f webpack-dev-server; webpack-dev-server; exit 0",
    "storybook": "kurama storybook",
    "test": "yarn test:unit",
    "test:coverage": "yarn jest --clearCache && yarn test:unit --no-cache --coverage true",
    "test:scopedcoverage": "yarn test:unit --no-cache $SCOPE --coverage --collectCoverageFrom=$SCOPE/**/*.ts*",
    "test:ui": "NODE_ENV=test start-server-and-test start:ci http://localhost:3032 test:ui:start",
    "test:ui:ci": "NODE_ENV=test start-server-and-test start:ci http://localhost:3032 'cypress run --config watchForFileChanges=false --browser electron'",
    "test:ui:clear": "rm -rf ./.coverage/cypress-coverage",
    "test:ui:start": "NODE_ENV=test npx cypress open",
    "test:unit": "LANG=en_US TZ=UTC NODE_ENV=test kurama test --config config/_jest/jest.specs.js",
    "typecheck": "tsc -p ./tsconfig.lint.json"
  },
  "dependencies": {
    "@apollo/client": "3.4.14",
    "@sentry/webpack-plugin": "^1.18.3",
    "@staff-portal/app-shell": "0.1.25",
    "@staff-portal/billing": "0.0.1",
    "@staff-portal/billing-widgets": "0.0.1",
    "@staff-portal/charts": "0.0.3",
    "@staff-portal/config": "0.137.7",
    "@staff-portal/counters": "0.0.1",
    "@staff-portal/data-layer-service": "0.3.24",
    "@staff-portal/date-time-utils": "0.5.24",
    "@staff-portal/dependency-injector": "0.0.1",
    "@staff-portal/editable": "0.2.30",
    "@staff-portal/error-handling": "0.1.24",
    "@staff-portal/facilities": "0.0.23",
    "@staff-portal/filters": "0.0.1",
    "@staff-portal/forms": "0.2.30",
    "@staff-portal/graphql": "0.4.0",
    "@staff-portal/jobs": "0.0.30",
    "@staff-portal/local-storage-service": "0.142.3",
    "@staff-portal/mutation-result-handlers": "0.2.18",
    "@staff-portal/navigation": "0.151.0",
    "@staff-portal/operations": "0.5.13",
    "@staff-portal/page-wrapper": "0.0.1",
    "@staff-portal/query-params-state": "0.1.7",
    "@staff-portal/ui": "0.10.13",
    "@staff-portal/utils": "0.0.2",
    "@staff-portal/validators": "0.0.7",
    "@topkit/react-router": "^0.3.4",
    "@toptal/staff-portal-message-bus": "1.0.22",
    "i18next": "^20.4.0",
    "lodash-es": "^4.17.21",
    "luxon": "^1.25.0",
    "react": "16.14.0",
    "react-dom": "16.14.0",
    "react-i18next": "^11.10.0",
    "styled-components": "5.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.10.2",
    "@babel/plugin-proposal-class-properties": "^7.4.4",
    "@babel/plugin-proposal-export-default-from": "^7.10.4",
    "@babel/plugin-proposal-object-rest-spread": "^7.13.0",
    "@babel/plugin-proposal-optional-chaining": "^7.13.0",
    "@babel/plugin-transform-async-to-generator": "^7.10.1",
    "@babel/plugin-transform-react-constant-elements": "^7.2.0",
    "@babel/plugin-transform-react-display-name": "^7.2.0",
    "@babel/plugin-transform-react-inline-elements": "^7.10.1",
    "@babel/plugin-transform-react-jsx": "^7.10.4",
    "@babel/preset-env": "^7.14.2",
    "@babel/preset-react": "^7.13.13",
    "@babel/preset-typescript": "^7.15.0",
    "@cypress/code-coverage": "^3.9.4",
    "@cypress/webpack-preprocessor": "^5.9.1",
    "@miovision/eslint-plugin-disallow-date": "^2.0.0",
    "@pact-foundation/pact": "^9.16.0",
    "@pact-foundation/pact-node": "^10.17.0",
    "@testing-library/react": "^11.2.6",
    "@testing-library/react-hooks": "^8.0.0",
    "@topkit/router": "^0.6.4",
    "@toptal/picasso": "^25.0.0",
    "@toptal/picasso-forms": "^44.0.0",
    "@toptal/picasso-provider": "^1.1.2",
    "@types/color": "^3.0.0",
    "@types/lodash-es": "^4.17.4",
    "@types/luxon": "^1.26.1",
    "@types/node": "^16.3.3",
    "@types/pluralize": "^0.0.29",
    "@types/react": "^16.9.35",
    "@types/react-dom": "^16.9.0",
    "@types/react-router-dom": "^5.1.5",
    "@types/styled-components": "^5.1.2",
    "@types/webpack-dev-server": "^3.11.2",
    "babel-loader": "8.2.2",
    "babel-plugin-istanbul": "^6.0.0",
    "babel-plugin-styled-components": "1.12.0",
    "color": "^3.1.3",
    "cross-env": "^7.0.3",
    "cypress": "^7.5.0",
    "cypress-react-selector": "^2.3.6",
    "danger": "^10.6.3",
    "eslint-plugin-cypress": "^2.11.2",
    "eventemitter2": "^6.4.4",
    "fs-extra": "^10.0.0",
    "graphql": "^15.5.0",
    "graphql-tag": "^2.12.4",
    "html-webpack-plugin": "^5.3.2",
    "hygen": "^6.0.4",
    "jest-when": "^3.3.1",
    "mockdate": "^3.0.5",
    "nyc": "^15.1.0",
    "pug": "^3.0.1",
    "pug-loader": "^2.4.0",
    "react-router-dom": "^5.2.0",
    "react-test-renderer": "^16.13.1",
    "regenerator-runtime": "^0.13.7",
    "resolve-ts-aliases": "^1.0.1",
    "start-server-and-test": "^1.12.5",
    "terser-webpack-plugin": "^5.1.4",
    "typescript": "4.6.2",
    "url-loader": "^4.1.1",
    "use-debounce": "^7.0.0",
    "webpack": "^5",
    "webpack-bundle-analyzer": "^4.3.0",
    "webpack-cli": "^3.3.6",
    "webpack-dev-server": "^3.11.2",
    "webpack-merge": "^5.8.0"
  },
  "peerDependencies": {
    "@topkit/router": "^0.6.4",
    "@toptal/picasso": "^25.0.0",
    "react": "16.14.0",
    "react-dom": "16.14.0",
    "react-router-dom": "^5.2.0",
    "use-debounce": "^7.0.0"
  },
  "nyc": {
    "extends": "nyc.config.js"
  },
  "sideEffects": false
}
