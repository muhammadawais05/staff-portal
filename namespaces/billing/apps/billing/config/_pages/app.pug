doctype html
html.layout.no-js(lang="en")
  head
    meta(charset="utf-8")
    title=htmlWebpackPlugin.options.title
    meta(name="viewport" content="width=device-width, initial-scale=1")
  body
    div
      div#root
    div#react_modal
    div#react_notification

    style(type="text/css").
      #react_modal *,
      #react_notification * {
        box-sizing: border-box
      }
